{
  "name": "toastmasters-district-visualizer",
  "version": "2.9.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rservant/toast-stats.git"
  },
  "private": true,
  "workspaces": [
    "frontend",
    "packages/collector-cli",
    "packages/analytics-core",
    "packages/shared-contracts"
  ],
  "scripts": {
    "dev:frontend": "npm run dev --workspace=frontend",
    "build:frontend": "npm run build --workspace=frontend",
    "build:collector-cli": "npm run build --workspace=@toastmasters/collector-cli",
    "build:analytics-core": "npm run build --workspace=@toastmasters/analytics-core",
    "build:shared-contracts": "npm run build --workspace=@toastmasters/shared-contracts",
    "collector-cli": "npm run start --workspace=@toastmasters/collector-cli --",
    "test:frontend": "npm run test --workspace=frontend",
    "test:collector-cli": "npm run test --workspace=@toastmasters/collector-cli",
    "test:analytics-core": "npm run test --workspace=@toastmasters/analytics-core",
    "test:shared-contracts": "npm run test --workspace=@toastmasters/shared-contracts",
    "test": "npm run test --workspaces",
    "test:coverage": "npm run test --workspaces -- --coverage",
    "test:watch": "npm run test:watch --workspaces --if-present",
    "lint": "npm run lint --workspaces",
    "lint:yaml": "yamllint -c .yamllint.yml .github/ docs/",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "typecheck": "npm run typecheck --workspaces",
    "typecheck:frontend": "npm run typecheck --workspace=frontend",
    "typecheck:count": "npm run typecheck:count --workspaces",
    "quality:check": "npm run lint && npm run lint:yaml && npm run typecheck && npm run format:check && npm run test",
    "quality:fix": "npm run lint --workspaces -- --fix && npm run format",
    "pre-commit": "npm run typecheck && npm run lint && npm run lint:yaml",
    "prepare": "husky install",
    "cleanup:test-dirs": "bash scripts/cleanup-all-test-dirs.sh",
    "cleanup:frontend": "bash frontend/scripts/cleanup-test-dirs.sh",
    "pipeline:dry-run": "npx tsx scripts/prune-month-end-pipeline.ts --dry-run",
    "pipeline:run": "npx tsx scripts/prune-month-end-pipeline.ts --execute",
    "pipeline:step": "npx tsx scripts/prune-month-end-pipeline.ts"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.4",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.2",
    "tsx": "^4.21.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,md}": "prettier --write"
  },
  "overrides": {
    "minimatch": "^10.2.3",
    "fast-xml-parser": "^5.5.8",
    "flatted": "^3.3.3",
    "vite": "^7.3.2",
    "@google-cloud/storage": {
      "teeny-request": {
        "http-proxy-agent": "^7.0.0"
      }
    }
  }
}
