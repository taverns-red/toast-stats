{
  "name": "frontend",
  "license": "MIT",
  "private": true,
  "version": "2.10.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 500",
    "test": "vitest --run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit --skipLibCheck --project tsconfig.json",
    "typecheck:count": "tsc --noEmit --skipLibCheck --project tsconfig.json 2>&1 | grep -E \"error TS[0-9]+\" | wc -l || echo \"0\"",
    "typecheck:errors": "tsc --noEmit --skipLibCheck --project tsconfig.json 2>&1 | grep -E \"error TS[0-9]+\" || echo \"No TypeScript errors found\"",
    "typecheck:prod": "tsc --noEmit --project tsconfig.json",
    "typecheck:test": "tsc --noEmit --project tsconfig.test.json",
    "typecheck:all": "npm run typecheck:prod && npm run typecheck:test",
    "cleanup:test-dirs": "./scripts/cleanup-test-dirs.sh"
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@tanstack/react-query": "^5.96.2",
    "@toastmasters/shared-contracts": "^1.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.14.0",
    "recharts": "^3.8.0",
    "tailwindcss": "^4.1.18"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.5.1",
    "@types/jest-axe": "^3.5.9",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.56.0",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^4.1.3",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.0",
    "fast-check": "^4.6.0",
    "globals": "^17.4.0",
    "jest-axe": "^10.0.0",
    "jsdom": "^29.0.2",
    "postcss": "^8.5.12",
    "typescript": "^5.2.2",
    "vite": "^7.3.2",
    "vitest": "^4.0.18"
  }
}
